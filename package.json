{
  "name": "gha-bom",
  "version": "0.1.1",
  "description": "Offline GitHub Actions bill of materials, risk map, and diff tool.",
  "type": "module",
  "license": "MIT",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24 <25"
  },
  "bin": {
    "gha-bom": "./dist/cli.js",
    "gbom": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "LAUNCH.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "docs",
    "examples",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iDogRoag/gha-bom.git"
  },
  "bugs": {
    "url": "https://github.com/iDogRoag/gha-bom/issues"
  },
  "homepage": "https://github.com/iDogRoag/gha-bom#readme",
  "keywords": [
    "github-actions",
    "security",
    "sbom",
    "bom",
    "ci",
    "cicd",
    "supply-chain",
    "devsecops",
    "workflow",
    "actions",
    "static-analysis",
    "developer-tools"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "strip-ansi": "^7.1.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
